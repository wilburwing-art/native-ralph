# Google AI API key (required for default Gemini model)
GOOGLE_API_KEY=your-google-api-key-here

# Target URL for browser testing (default: http://localhost:3000)
# ADK_TARGET_URL=http://localhost:3000

# Maximum refinement iterations (default: 5)
# ADK_MAX_ITERATIONS=5

# Model override (default: gemini-2.0-flash)
# ADK_MODEL=gemini-2.0-flash

# Path to browser-tests directory (default: auto-detected)
# ADK_BROWSER_TESTS_DIR=./browser-tests
